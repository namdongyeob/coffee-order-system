#!/usr/bin/env sh
set -eu

repository_root="$(git rev-parse --show-toplevel)"
cd "$repository_root"

if command -v python >/dev/null 2>&1; then
  exec python scripts/harness_gate.py --base-ref origin/main --check-links
fi

if command -v python3 >/dev/null 2>&1; then
  exec python3 scripts/harness_gate.py --base-ref origin/main --check-links
fi

echo "ERROR: Python 3 is required for the repository pre-push hook." >&2
exit 1
